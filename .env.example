# --- Pipeline ---
# GITHUB_TOKEN опционально — `gh` CLI обычно использует свою auth.
# GITHUB_TOKEN=ghp_...
SOURCE_REPO=your-org/the-foundry-sandbox
TARGET_REPO=your-org/the-foundry-sandbox
ISSUE_LABEL=agent-task
WORKTREE_ROOT=./worktrees
DB_PATH=./data/foundry.sqlite
POLL_INTERVAL_SECONDS=30

# --- Coding agent ---
# DEEPSEEK | ANTHROPIC | CHATGPT
CODING_LLM=DEEPSEEK
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AIDER_TIMEOUT_SECONDS=600
