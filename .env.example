# =============================================================================
# The Foundry — sample .env
# Copy to `.env` and fill SOURCE_REPO / TARGET_REPO at minimum.
# =============================================================================

# --- GitHub side (required) ---------------------------------------------------
# Both can point at the same sandbox repo for local experiments.
SOURCE_REPO=your-org/the-foundry-sandbox
TARGET_REPO=your-org/the-foundry-sandbox
# Branch used for worktrees and PR base.
BASE_BRANCH=main
# Issues with this label are picked up by `foundry run`.
ISSUE_LABEL=agent-task
# Optional queue filters for `foundry run`. ISSUE_LABELS is comma-separated and
# supersedes ISSUE_LABEL when set. GitHub returns issues matching all labels.
# ISSUE_LABELS=agent-task,queue/backend
# ISSUE_ASSIGNEE=octocat
# ISSUE_MILESTONE=v1
# ISSUE_LIMIT=50
# `gh` CLI handles GitHub auth; this var is currently unused — leave commented.
# GITHUB_TOKEN=ghp_...

# --- Real project example: podlodka-ai-club/the-foundry ----------------------
# SOURCE_REPO=podlodka-ai-club/the-foundry
# TARGET_REPO=podlodka-ai-club/the-foundry
# BASE_BRANCH=main
# ISSUE_LABEL=foundry-task
# VERIFY_COMMANDS=[["uv","run","ruff","check","."],["uv","run","pytest","-x","--no-header","-q"],["npm","--prefix","web","ci"],["npm","--prefix","web","run","build"],["npm","--prefix","web","run","lint"]]

# --- Storage / scheduling -----------------------------------------------------
WORKTREE_ROOT=./worktrees
DB_PATH=./data/foundry.sqlite
# How often `foundry run` (without --once) re-fetches issues, seconds.
POLL_INTERVAL_SECONDS=30
# How many implement→verify attempts inside one task before giving up.
MAX_IMPLEMENT_ATTEMPTS=2

# --- Verify stage -------------------------------------------------------------
# Deterministic checks run before the LLM reviewer. If any non-zero exits, the
# attempt fails as `deterministic` and the agent reviewer is skipped.
#
# Auto-detect by default:
#   pyproject.toml + tests/  → uv run ruff check . ; uv run pytest -x --no-header -q
#   package.json             → npm ci ; npm run build/lint/test when scripts exist
#   Cargo.toml               → cargo test
# Override with a JSON array of argv arrays. Empty list disables deterministic
# checks entirely (the LLM reviewer alone decides PASS/FAIL).
# VERIFY_COMMANDS=[["uv","run","ruff","check","."],["uv","run","pytest","-x","-q"]]
# Per-command timeout (seconds).
# VERIFY_COMMAND_TIMEOUT_SEC=300
# Cap on diff sent to the reviewer agent — anything larger collapses to
# `git diff --stat` plus a truncation marker.
# VERIFY_DIFF_MAX_BYTES=200000

# =============================================================================
# Coding agents
# Per-stage env (`AGENT_PLAN_*`, `AGENT_IMPLEMENT_*`, `AGENT_VERIFY_*`) wins
# over global `AGENT_*`, which wins over hard-coded defaults.
# =============================================================================

# Backend: stub (default, offline) | claude_cli | codex_cli | opencode_cli
CODING_AGENT=stub

# Default model — interpreted by the chosen backend:
#   claude_cli:    haiku | sonnet | opus | <full id>
#   codex_cli:     gpt-5 | gpt-4o | <full id>
#   opencode_cli:  <provider>/<model>, e.g. openrouter/anthropic/claude-haiku-4.5
AGENT_MODEL=haiku
AGENT_TIMEOUT_SEC=300
AGENT_MAX_TURNS=10
# Safe by default: do not pass Claude/Codex dangerous bypass flags.
# Set to false only in a disposable sandbox you are prepared to lose.
SAFE_AGENT_MODE=true
# Optional Codex CLI sandbox mode. In Docker Compose the default is
# danger-full-access to avoid bubblewrap/user namespace failures inside the
# container (`bwrap: No permissions to create a new namespace`).
# CODEX_SANDBOX_MODE=workspace-write
# Optional comma-separated env vars to pass through to agent subprocesses in
# addition to the small built-in allowlist and backend auth keys.
# AGENT_ENV_ALLOWLIST=

# Auth per backend:
#   claude_cli:    `claude /login` (subscription OAuth) or ANTHROPIC_API_KEY
#   codex_cli:     `codex login` (ChatGPT Plus/Pro) or OPENAI_API_KEY
#   opencode_cli:  reads provider keys from env, e.g. OPENROUTER_API_KEY

# --- Per-stage overrides (optional) -------------------------------------------
# AGENT_PLAN_MODEL=haiku
# AGENT_IMPLEMENT_MODEL=sonnet
# AGENT_VERIFY_MODEL=haiku
# AGENT_PLAN_MAX_TURNS=5
# AGENT_IMPLEMENT_MAX_TURNS=30
# AGENT_VERIFY_MAX_TURNS=5
# AGENT_IMPLEMENT_BACKEND=claude_cli

# --- Live example: real LLM via Claude Code -----------------------------------
# Uncomment the block below to switch the pipeline from `stub` to `claude_cli`.
# Prereqs:
#   1. `brew install --cask claude`
#   2. `claude /login` (subscription) OR export ANTHROPIC_API_KEY=...
#   3. Comment out CODING_AGENT=stub above.
#
# CODING_AGENT=claude_cli
# AGENT_MODEL=sonnet
# AGENT_MAX_TURNS=20
# AGENT_TIMEOUT_SEC=600
# AGENT_PLAN_MODEL=haiku
# AGENT_VERIFY_MODEL=haiku
# AGENT_IMPLEMENT_MODEL=sonnet
# AGENT_IMPLEMENT_MAX_TURNS=40

# --- Live example: OpenCode + DeepSeek (API key) ------------------------------
# Альтернатива Claude — opencode CLI с DeepSeek API ключом (дёшево, без подписки).
# Prereqs:
#   1. `curl -fsSL https://opencode.ai/install | bash`  (или brew/npm — см. README)
#   2. Получить ключ на https://platform.deepseek.com/ и положить в auth.json:
#        mkdir -p ~/.local/share/opencode
#        echo '{"deepseek":{"type":"api","key":"sk-..."}}' > ~/.local/share/opencode/auth.json
#   3. Smoke: `opencode run -m deepseek/deepseek-v4-flash "hi"`
#   4. Comment out CODING_AGENT=stub above.
# Полный список провайдеров и моделей: https://opencode.ai/docs/providers/
#
# CODING_AGENT=opencode_cli
# AGENT_MODEL=deepseek/deepseek-v4-flash
# AGENT_MAX_TURNS=20
# AGENT_TIMEOUT_SEC=600
# AGENT_PLAN_MODEL=deepseek/deepseek-v4-flash
# AGENT_VERIFY_MODEL=deepseek/deepseek-v4-flash
# AGENT_IMPLEMENT_MODEL=deepseek/deepseek-v4-pro
# AGENT_IMPLEMENT_MAX_TURNS=40

# =============================================================================
# Langfuse observability (optional)
# Sign up at cloud.langfuse.com (US) or eu.cloud.langfuse.com (EU).
# Missing keys → tracing is disabled gracefully, no errors.
# =============================================================================
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com
