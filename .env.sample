# DIRS
AGENT_DIR=agent
AGENT_SOURCES_DIR=code
AGENT_TASKS_DIR=agent/tasks

# LLM used for Coding in Aider
# variants: DEEPSEEK | ANTHROPIC | CHATGPT
CODING_LLM=DEEPSEEK

# DeepSeek
DEEPSEEK_API_KEY=your-api-key-here
DEEPSEEK_MODEL_NAME=deepseek/deepseek-chat

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-key-here
ANTHROPIC_MODEL_NAME=claude-3-5-sonnet-20241022

# ChatGPT
CHATGPT_API_KEY=your-openai-key-here
CHATGPT_MODEL_NAME=gpt-4