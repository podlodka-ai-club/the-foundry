# --- Pipeline ---
SOURCE_REPO=your-org/the-foundry-sandbox
TARGET_REPO=your-org/the-foundry-sandbox
ISSUE_LABEL=agent-task
WORKTREE_ROOT=./worktrees
DB_PATH=./data/foundry.sqlite
POLL_INTERVAL_SECONDS=30

# Опционально: токен с правом repo. Если пусто — используется gh auth.
GITHUB_TOKEN=

# --- Coding agent ---
# Какой LLM-провайдер использует aider. Варианты: DEEPSEEK | ANTHROPIC | CHATGPT
CODING_LLM=DEEPSEEK

# Достаточно ключа того провайдера, что выбран в CODING_LLM.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL_NAME=

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_NAME=

# Поддерживается и OPENAI_API_KEY, и CHATGPT_API_KEY (oai стандарт предпочтительнее).
OPENAI_API_KEY=
CHATGPT_MODEL_NAME=

# Сколько секунд ждать aider до таймаута (per-task).
AIDER_TIMEOUT_SECONDS=600
