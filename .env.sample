# Директория ИИ кодинг агента
AGENT_DIR=./agent

# Директория с кодом для работы агента
# Относительный путь (по умолчанию): code
# Абсолютный путь (требует AGENT_ALLOW_ABSOLUTE_PATHS=true): /home/user/my-project/src
AGENT_SOURCES_DIR=./code

# Разрешить использование абсолютных путей в AGENT_SOURCES_DIR
# ВАЖНО: Используйте только для безопасных директорий!
# Запрещены: /etc, /usr, /bin, /sbin, /boot, /sys, /proc, /dev, /var, /root, ~/.ssh, ~/.config
AGENT_ALLOW_ABSOLUTE_PATHS=true

# Директория, где хранятся тексты задач для агента и логи по их выполнению
AGENT_TASKS_DIR=./agent/tasks

# LLM used for Coding in Aider
# variants: DEEPSEEK | ANTHROPIC | CHATGPT
CODING_LLM=DEEPSEEK

# DeepSeek
DEEPSEEK_API_KEY=your-api-key-here
DEEPSEEK_MODEL_NAME=deepseek/deepseek-chat

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-key-here
ANTHROPIC_MODEL_NAME=claude-3-5-sonnet-20241022

# ChatGPT
CHATGPT_API_KEY=your-openai-key-here
CHATGPT_MODEL_NAME=gpt-4