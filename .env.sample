# DIRS
AGENT_DIR=aider
AGENT_SOURCES_DIR=code
AGENT_TASKS_DIR=aider/tasks

# LLM settings
CODING_LLM=DEEPSEEK

# DeepSeek
DEEPSEEK_API_KEY=your-api-key-here
DEEPSEEK_MODEL_NAME=deepseek/deepseek-chat
# Примечание: DeepSeek может выводить рассуждения (thinking mode) перед ответом,
# что приводит к созданию файлов с неправильными именами.
# Пост-обработка автоматически исправляет такие имена файлов.
# Для полного отключения thinking mode используйте модель deepseek-reasoner
# с параметром thinking: disabled (требует настройки через .aider.model.metadata.json)

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-key-here
ANTHROPIC_MODEL_NAME=claude-3-5-sonnet-20241022

# ChatGPT
CHATGPT_API_KEY=your-openai-key-here
CHATGPT_MODEL_NAME=gpt-4